{
  "version": "2.0",
  "description": "Rust 编程规范统一注册表 — 所有 46 条规范条目及其检查方式",
  "check_types": {
    "clippy_native": "clippy 原生 lint，有规范映射，默认启用",
    "clippy_custom": "扩展工具自定义 lint，有规范映射，需 -W 显式启用",
    "llm": "工具无法检查，由 LLM 代码审查覆盖"
  },
  "guidelines": [
    {
      "guideline_code": "G.NAM.01",
      "title": "应使用统一的命名风格",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["non_camel_case_types", "non_snake_case", "non_upper_case_globals"]
    },
    {
      "guideline_code": "G.NAM.02",
      "title": "类型转换函数命名宜遵循所有权语义",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::wrong_self_convention"]
    },
    {
      "guideline_code": "G.CMT.01",
      "title": "公开的 API 需要文档注释",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::missing_errors_doc", "clippy::missing_panics_doc", "clippy::missing_safety_doc", "clippy::undocumented_unsafe_blocks"]
    },
    {
      "guideline_code": "G.CMT.02",
      "title": "文件头注释应包含版权说明",
      "level": "suggestion",
      "check_type": "llm",
      "lint_codes": []
    },
    {
      "guideline_code": "G.FMT.01",
      "title": "extern 外部函数应显式指定 ABI 标识",
      "level": "requirement",
      "check_type": "llm",
      "lint_codes": []
    },
    {
      "guideline_code": "G.CNS.01",
      "title": "常量类型不应具有内部可变性",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::borrow_interior_mutable_const", "clippy::declare_interior_mutable_const"]
    },
    {
      "guideline_code": "G.CNS.02",
      "title": "宜使用标准库中的预定义常量",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::approx_constant"]
    },
    {
      "guideline_code": "G.TYP.01",
      "title": "数值字面量要添加明确的类型标识",
      "level": "suggestion",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::unconstrained_numeric_literal"]
    },
    {
      "guideline_code": "G.TYP.BOL.01",
      "title": "不宜使用块表达式作为控制表达式",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::blocks_in_conditions"]
    },
    {
      "guideline_code": "G.TYP.BOL.02",
      "title": "不宜将布尔变量和布尔字面量进行比较",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::bool_assert_comparison", "clippy::bool_comparison"]
    },
    {
      "guideline_code": "G.TYP.BOL.03",
      "title": "&& 和 || 操作符的右侧操作中不应包含副作用",
      "level": "suggestion",
      "check_type": "llm",
      "lint_codes": []
    },
    {
      "guideline_code": "G.TYP.CHR.01",
      "title": "整数到字符的类型转换应注意有效范围",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::invalid_char_range"]
    },
    {
      "guideline_code": "G.TYP.INT.01",
      "title": "整数类型的算数运算",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::arithmetic_side_effects"]
    },
    {
      "guideline_code": "G.TYP.SLC.01",
      "title": "宜使用迭代器而非下标遍历切片和数组",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::needless_range_loop"]
    },
    {
      "guideline_code": "G.TYP.SLC.02",
      "title": "应保证数组索引在有效范围内",
      "level": "requirement",
      "check_type": "clippy_native",
      "lint_codes": ["unconditional_panic"]
    },
    {
      "guideline_code": "G.TYP.SCT.01",
      "title": "外部使用的自定义类型宜实现常见 trait",
      "level": "suggestion",
      "check_type": "llm",
      "lint_codes": []
    },
    {
      "guideline_code": "G.TYP.STR.01",
      "title": "在实现 Display trait 时不应调用 to_string() 方法",
      "level": "requirement",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::recursive_format_impl"]
    },
    {
      "guideline_code": "G.TYP.PTR.01",
      "title": "Rc Arc Box 不应相互嵌套使用",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::redundant_allocation"]
    },
    {
      "guideline_code": "G.CTF.01",
      "title": "宜优先使用模式匹配而非判断后再取值",
      "level": "suggestion",
      "check_type": "llm",
      "lint_codes": []
    },
    {
      "guideline_code": "G.CTF.02",
      "title": "Match Guard 中不应使用带副作用的条件表达式",
      "level": "suggestion",
      "check_type": "llm",
      "lint_codes": []
    },
    {
      "guideline_code": "G.CTF.03",
      "title": "循环或递归必须安全退出",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::infinite_loop"]
    },
    {
      "guideline_code": "G.EXP.01",
      "title": "避免复合条件表达式永远为 true 或 false",
      "level": "requirement",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::bad_bit_mask"]
    },
    {
      "guideline_code": "G.EXP.02",
      "title": "用括号明确表达式的操作顺序",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::precedence"]
    },
    {
      "guideline_code": "G.FUD.01",
      "title": "内存拷贝代价大的参数应按地址传递",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::large_types_passed_by_value"]
    },
    {
      "guideline_code": "G.FUD.02",
      "title": "可能出错的函数，应保证用户不可忽略返回值",
      "level": "requirement",
      "check_type": "clippy_native",
      "lint_codes": ["unused_must_use"]
    },
    {
      "guideline_code": "G.TRA.01",
      "title": "在实现相等性、排序和散列类 trait 时，应保证一致性",
      "level": "requirement",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::derive_ord_xor_partial_ord"]
    },
    {
      "guideline_code": "G.TRA.02",
      "title": "宜实现 From 而不是 Into",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::from_over_into"]
    },
    {
      "guideline_code": "G.ERR.01",
      "title": "应正确处理返回类型 Option 和 Result",
      "level": "requirement",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::unwrap_used"]
    },
    {
      "guideline_code": "G.MOD.01",
      "title": "导入模块中的类型或函数时，应避免直接使用通配符",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::wildcard_imports"]
    },
    {
      "guideline_code": "G.MAC.DCL.01",
      "title": "编写宏匹配规则时，宜遵从匹配范围从小至大的顺序",
      "level": "suggestion",
      "check_type": "llm",
      "lint_codes": []
    },
    {
      "guideline_code": "G.MAC.PRO.011",
      "title": "不应通过过程宏将 unsafe 代码包装为 safe 代码",
      "level": "requirement",
      "check_type": "llm",
      "lint_codes": []
    },
    {
      "guideline_code": "G.MAC.01",
      "title": "不应该通过宏将 unsafe 代码伪装为 safe 代码",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::unsafe_block_in_proc_macro"]
    },
    {
      "guideline_code": "G.SAF.UNS.01",
      "title": "禁止将外部可控数据作为加载动态库的参数",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::untrusted_lib_loading"]
    },
    {
      "guideline_code": "G.SAF.UNS.02",
      "title": "禁止从不可变引用创建可变引用",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::mut_from_ref"]
    },
    {
      "guideline_code": "G.SAF.FFI.01",
      "title": "FFI 边界应确保字符串参数正确传递和使用",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::passing_string_to_c_functions"]
    },
    {
      "guideline_code": "G.SAF.FFI.02",
      "title": "在 FFI 调用的场景下，应确保跨边界数据的内存布局兼容",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::extern_without_repr"]
    },
    {
      "guideline_code": "G.SAF.FFI.03",
      "title": "禁止调用 C 不可重入函数",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::non_reentrant_functions"]
    },
    {
      "guideline_code": "G.SAF.FFI.04",
      "title": "禁止使用外部内存不安全函数",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::mem_unsafe_functions"]
    },
    {
      "guideline_code": "G.SAF.FFI.05",
      "title": "extern 块应显式标注 ABI",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::implicit_abi"]
    },
    {
      "guideline_code": "G.SAF.ASY.01",
      "title": "避免在异步处理过程中包含阻塞操作",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::blocking_op_in_async"]
    },
    {
      "guideline_code": "G.SAF.MTH.01",
      "title": "多线程场景下，对于共享的标量类型数据，宜使用对应的原子类型",
      "level": "suggestion",
      "check_type": "clippy_native",
      "lint_codes": ["clippy::mutex_atomic", "clippy::mutex_integer"]
    },
    {
      "guideline_code": "G.SAF.MEM.01",
      "title": "应校验内存申请函数的输入参数和返回值",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::fallible_memory_allocation"]
    },
    {
      "guideline_code": "G.SAF.MEM.02",
      "title": "Unsafe 模式下，使用指针及内存地址时应确保有效性",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::dangling_ptr_dereference", "clippy::null_ptr_dereference", "clippy::return_stack_address"]
    },
    {
      "guideline_code": "G.SAF.MEM.03",
      "title": "Unsafe 模式下，应正确释放申请的内存",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::ptr_double_free"]
    },
    {
      "guideline_code": "G.SAF.MEM.04",
      "title": "内存中的敏感信息使用完毕后应立即清零",
      "level": "requirement",
      "check_type": "llm",
      "lint_codes": []
    },
    {
      "guideline_code": "G.OTH.01",
      "title": "禁止硬编码 IP 地址",
      "level": "requirement",
      "check_type": "clippy_custom",
      "lint_codes": ["clippy::hard_coded_ip"]
    }
  ]
}
